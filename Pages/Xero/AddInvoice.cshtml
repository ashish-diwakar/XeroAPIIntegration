@page
@model XeroDemo.Pages.Xero.AddInvoiceModel
@{
    ViewData["Title"] = "Xero Contact Invoice Builder";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm p-4">
                <h2 class="text-center mb-4 text-primary">Xero Contact Manager</h2>

                <!-- PHASE 1: Fetch button shows when no contacts choices have been loaded yet -->
                @if (Model.XeroContactsList.Count == 0 && string.IsNullOrEmpty(Model.SelectedContactId))
                {
                    <div class="text-center border p-4 rounded bg-light">
                        <p class="text-muted">Connect your session to fetch active contacts from API.</p>
                        <form method="post" asp-page-handler="FetchContact">
                            <button type="submit" class="btn btn-success btn-lg w-100">🔌 Fetch Contacts List</button>
                        </form>
                    </div>
                }
                else
                {
                    <!-- PHASE 2: Renders dynamic drop down selection menu and contact text box -->
                    <form method="post" asp-page-handler="CreateInvoice">

                        <!-- Dynamic Contact Dropdown -->
                        <div class="mb-3">
                            <label asp-for="SelectedContactId" class="form-label fw-bold"></label>
                            <select asp-for="SelectedContactId" asp-items="Model.XeroContactsList" class="form-select form-select-lg">
                                <option value="">-- Choose Xero Business Contact --</option>
                            </select>
                            <span asp-validation-for="SelectedContactId" class="text-danger small d-block mt-1"></span>
                        </div>


                        <!-- Retain items list inside hidden input formats across submission actions -->
                        @for (int i = 0; i < Model.XeroContactsList.Count; i++)
                        {
                            <input type="hidden" name="XeroContactsList[@i].Value" value="@Model.XeroContactsList[i].Value" />
                            <input type="hidden" name="XeroContactsList[@i].Text" value="@Model.XeroContactsList[i].Text" />
                        }

                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-primary btn-lg">📄 Create Demo Invoice for Selection</button>
                        </div>
                    </form>
                }

                <!-- Feedback Logs -->
                @if (!string.IsNullOrEmpty(Model.ApiResult))
                {
                    <div class="mt-4 alert alert-info text-start">
                        <h6 class="fw-bold">Execution Log / Response:</h6>
                        <pre class="bg-light p-2 border rounded"><code class="small text-wrap">@Model.ApiResult</code></pre>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}